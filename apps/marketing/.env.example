# Marketing site (SSR React Router app). Runtime, server-side env vars — set them
# in the hosting environment, not baked into the client bundle. Copy to .env for
# local dev if your runner loads dotenv; otherwise export them in your shell.

# Base origin of the Xtiitch API — WITHOUT the /v1 suffix, no trailing slash.
# The app appends /v1/... itself. Used for the public shops directory + sponsored
# placements. Defaults to http://localhost:8080 if unset.
XTIITCH_API_URL=http://localhost:8085

# Where marketing CTAs/links point for the other surfaces.
XTIITCH_DASHBOARD_URL=http://localhost:3401
XTIITCH_STOREFRONT_BASE_URL=http://localhost:3100

# Waitlist capture (optional). If RESEND_API_KEY + RESEND_FROM_EMAIL +
# MARKETING_WAITLIST_EMAIL_TO are set, signups are emailed via Resend. If
# MARKETING_WAITLIST_WEBHOOK_URL is set, signups are also POSTed there (signed
# with MARKETING_WAITLIST_WEBHOOK_SECRET). Leave unset to no-op the waitlist.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Xtiitch <hello@xtiitch.com>
MARKETING_WAITLIST_EMAIL_TO=
MARKETING_WAITLIST_WEBHOOK_URL=
MARKETING_WAITLIST_WEBHOOK_SECRET=

# Set to "production" when hosting.
NODE_ENV=development
