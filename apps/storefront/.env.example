# Customer storefront (SSR React Router app). Runtime, server-side env var — set
# it in the hosting environment, not baked into the client bundle. Copy to .env
# for local dev if your runner loads dotenv; otherwise export it in your shell.

# Base origin of the Xtiitch API — WITHOUT the /v1 suffix, no trailing slash.
# The app appends /v1/... itself. Defaults to http://localhost:8080 if unset.
XTIITCH_API_URL=http://localhost:8085

# Signs the customer session cookie (phone-OTP sign-in for AI search). MUST be a
# strong, random value in production (a default dev secret is used when unset).
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "production" when hosting (enforces secure cookies / disables dev aids).
NODE_ENV=development
