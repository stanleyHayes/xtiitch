# Business dashboard (SSR React Router app). These are runtime, server-side env
# vars — set them in the hosting environment (Vercel/Render/Fly/Docker), not
# baked into the client bundle. Copy to .env for local dev if your runner loads
# dotenv; otherwise export them in your shell.

# Base origin of the Xtiitch API — WITHOUT the /v1 suffix, no trailing slash.
# The app appends /v1/... itself. Defaults to http://localhost:8080 if unset.
XTIITCH_API_URL=http://localhost:8085

# Secret that signs the business session cookie. MUST be a strong, random value
# in production (a default dev secret is used when unset — insecure for prod).
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "production" when hosting. The dashboard otherwise does a localhost
# dev-fallback for the API base, which must NOT happen in production.
NODE_ENV=development
