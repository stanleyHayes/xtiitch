{
  "extends": "../../tsconfig.base.json",
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "*.ts",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "rootDirs": [".", "./.react-router/types"],
    "types": ["node", "@react-router/node", "vite/client"],
    "jsx": "react-jsx",
    "noEmit": true
  }
}
