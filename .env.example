APP_ENV=development
API_HTTP_ADDR=:8080
BUSINESS_DASHBOARD_BASE_URL=http://localhost:3401
# The API connects as the non-superuser app role so row-level security is
# enforced. Run migrations as the owner (xtiitch) — e.g.
# postgres://xtiitch:xtiitch@localhost:5432/xtiitch?sslmode=disable
DATABASE_URL=postgres://xtiitch_app:xtiitch_app@localhost:5432/xtiitch?sslmode=disable
REDIS_URL=redis://localhost:6379/0
# Notification delivery transport: log | disabled | http | whatsapp_cloud.
# WhatsApp is the primary customer channel in Ghana — set whatsapp_cloud in prod.
NOTIFICATION_TRANSPORT=log
NOTIFICATION_HTTP_URL=
NOTIFICATION_HTTP_AUTH_HEADER=Authorization
NOTIFICATION_HTTP_AUTH_VALUE=
NOTIFICATION_HTTP_TIMEOUT_MS=10000
NOTIFICATION_FROM=Xtiitch
# WhatsApp Business Cloud API (Meta) — used when NOTIFICATION_TRANSPORT=whatsapp_cloud.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TIMEOUT_MS=10000
# Inbound WhatsApp ordering bot (API: GET/POST /v1/webhooks/whatsapp).
# WHATSAPP_VERIFY_TOKEN answers Meta's subscription challenge; WHATSAPP_APP_SECRET
# verifies the X-Hub-Signature-256 on inbound POSTs (required once the bot is
# enabled in production). The bot reuses WHATSAPP_PHONE_NUMBER_ID/ACCESS_TOKEN
# above to send replies; WHATSAPP_GRAPH_VERSION is the Graph API version for the
# Go sender (mirrors WHATSAPP_API_VERSION used by the worker). Leave the verify
# token empty to keep the bot dormant.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v21.0

# SMS (Arkesel) — auth OTPs + order notifications. OTP_CHANNEL=sms sends codes
# over SMS once ARKESEL_API_KEY is set (else falls back to WhatsApp, then logs).
# SMS_SENDER_ID is the approved alphanumeric sender name (<=11 chars).
OTP_CHANNEL=sms
SMS_SENDER_ID=Xtiitch
ARKESEL_API_KEY=
JWT_SIGNING_KEY=change-me-for-local-development
JWT_ISSUER=xtiitch-api
JWT_AUDIENCE=xtiitch-clients

# Opt-in TOTP MFA (authenticator apps). MFA_ISSUER is the label shown in the app.
# MFA_ENCRYPTION_KEY encrypts stored TOTP secrets at rest; leave empty to derive
# it from JWT_SIGNING_KEY (fine for local dev — set a dedicated key in production).
MFA_ISSUER=Xtiitch
MFA_ENCRYPTION_KEY=
ADMIN_BOOTSTRAP_EMAIL=owner@xtiitch.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=Xtiitch Owner
ADMIN_BOOTSTRAP_ROLE=owner
# Optional JSON array for local/demo operator accounts.
ADMIN_BOOTSTRAP_EXTRA_USERS_JSON=[]
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
CLOUDINARY_URL=
# Automated mail sends FROM this address only (keep it noreply@xtiitch.com so
# high-volume sending stays isolated from the human support@/billing@ inboxes).
# The app sets a Reply-To on every message — support@ for operational mail,
# billing@ for money mail — so replies reach a human.
# BEFORE LAUNCH: verify the sending domain in Resend and publish its SPF, DKIM
# and DMARC DNS records. Without them, transactional mail (OTPs, MoMo
# verification) lands in spam and silently fails. Verify with a real signup.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@xtiitch.com
MARKETING_WAITLIST_EMAIL_TO=
MARKETING_WAITLIST_WEBHOOK_URL=
MARKETING_WAITLIST_WEBHOOK_SECRET=
EXPO_ACCESS_TOKEN=

# AI marketplace search (API: POST /v1/public/ai-search).
# Both hops fall back to deterministic, key-free dev implementations when unset,
# so search runs locally with no keys. OPENAI_API_KEY switches embeddings to the
# hosted model; ANTHROPIC_API_KEY switches query understanding to Claude.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_QUERY_MODEL=claude-haiku-4-5-20251001

# Public storefront origin the API links to (e.g. WhatsApp bot "open shop" links).
STOREFRONT_BASE_URL=http://localhost:3100

# ── Web apps (admin / dashboard / marketing / storefront) ──────────────────────
# These are SSR React Router apps, deployed separately from the API. Each one
# reads XTIITCH_API_URL at runtime (server-side) to reach this API — set it to the
# API's public origin WITHOUT the /v1 suffix and WITHOUT a trailing slash, e.g.
# https://api.xtiitch.com. The browser never calls the API directly, so this is a
# server env var, not a build-time/public one. Each app also has its own
# apps/<app>/.env.example documenting its full set (SESSION_SECRET, NODE_ENV, …).
XTIITCH_API_URL=http://localhost:8085

# ── Internal scheduler (API + worker share these) ────────────────────────────
# Shared secret guarding the API's /v1/internal/* trigger endpoints (the worker
# sends it as the X-Internal-Token header; the API answers 404 for those
# endpoints while it is EMPTY — set it in production or no scheduled sweep
# runs). The worker fires, on a timer: recurring charges + renewal reminders
# (§13.3), scheduled reports (§14.1), settlement sync (§3.3).
XTIITCH_INTERNAL_TOKEN=
# Worker-side timing knobs (milliseconds; defaults shown). The worker reads
# XTIITCH_API_URL (above) to reach the API.
INTERNAL_API_TIMEOUT_MS=15000
RECURRING_CHARGES_SWEEP_INTERVAL_MS=86400000
RENEWAL_REMINDERS_SWEEP_INTERVAL_MS=86400000
SCHEDULED_REPORTS_INTERVAL_MS=86400000
SETTLEMENT_SYNC_INTERVAL_MS=900000

SONAR_HOST_URL=
SONAR_ORGANIZATION=
SONAR_TOKEN=
XTIITCH_LEGAL_REVIEW_CONFIRMED=false
XTIITCH_GROWTH_POLICY_CONFIRMED=false
