APP_ENV=development
API_HTTP_ADDR=:8080
BUSINESS_DASHBOARD_BASE_URL=http://localhost:3401
# The API connects as the non-superuser app role so row-level security is
# enforced. Run migrations as the owner (xtiitch) — e.g.
# postgres://xtiitch:xtiitch@localhost:5432/xtiitch?sslmode=disable
DATABASE_URL=postgres://xtiitch_app:xtiitch_app@localhost:5432/xtiitch?sslmode=disable
REDIS_URL=redis://localhost:6379/0
NOTIFICATION_TRANSPORT=log
NOTIFICATION_HTTP_URL=
NOTIFICATION_HTTP_AUTH_HEADER=Authorization
NOTIFICATION_HTTP_AUTH_VALUE=
NOTIFICATION_HTTP_TIMEOUT_MS=10000
NOTIFICATION_FROM=Xtiitch
JWT_SIGNING_KEY=change-me-for-local-development
JWT_ISSUER=xtiitch-api
JWT_AUDIENCE=xtiitch-clients

# Opt-in TOTP MFA (authenticator apps). MFA_ISSUER is the label shown in the app.
# MFA_ENCRYPTION_KEY encrypts stored TOTP secrets at rest; leave empty to derive
# it from JWT_SIGNING_KEY (fine for local dev — set a dedicated key in production).
MFA_ISSUER=Xtiitch
MFA_ENCRYPTION_KEY=
ADMIN_BOOTSTRAP_EMAIL=owner@xtiitch.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=Xtiitch Owner
ADMIN_BOOTSTRAP_ROLE=owner
# Optional JSON array for local/demo operator accounts.
ADMIN_BOOTSTRAP_EXTRA_USERS_JSON=[]
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
CLOUDINARY_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
MARKETING_WAITLIST_EMAIL_TO=
MARKETING_WAITLIST_WEBHOOK_URL=
MARKETING_WAITLIST_WEBHOOK_SECRET=
EXPO_ACCESS_TOKEN=
SONAR_HOST_URL=
SONAR_ORGANIZATION=
SONAR_TOKEN=
XTIITCH_LEGAL_REVIEW_CONFIRMED=false
XTIITCH_GROWTH_POLICY_CONFIRMED=false
