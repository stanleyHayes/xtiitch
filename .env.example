APP_ENV=development
API_HTTP_ADDR=:8080
# The API connects as the non-superuser app role so row-level security is
# enforced. Run migrations as the owner (xtiitch) — e.g.
# postgres://xtiitch:xtiitch@localhost:5432/xtiitch?sslmode=disable
DATABASE_URL=postgres://xtiitch_app:xtiitch_app@localhost:5432/xtiitch?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SIGNING_KEY=change-me-for-local-development
JWT_ISSUER=xtiitch-api
JWT_AUDIENCE=xtiitch-clients
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
CLOUDINARY_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
MARKETING_WAITLIST_EMAIL_TO=
MARKETING_WAITLIST_WEBHOOK_URL=
MARKETING_WAITLIST_WEBHOOK_SECRET=
EXPO_ACCESS_TOKEN=
