{
  "name": "xtiitch",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "check": "pnpm lint && node scripts/check-file-size.mjs && pnpm -r --if-present run check",
    "dev:api": "pnpm --filter @xtiitch/api dev",
    "dev:worker": "pnpm --filter @xtiitch/worker dev",
    "format": "pnpm -r --if-present run format",
    "launch:check": "node scripts/check-launch-gates.mjs",
    "load:storefront": "node scripts/load-storefront.mjs",
    "lint": "eslint . --max-warnings=9999",
    "quality": "pnpm test && pnpm sonar",
    "sonar:local": "node scripts/setup-local-sonar.mjs",
    "smoke:paystack": "node scripts/paystack-smoke.mjs",
    "smoke:whatsapp": "node scripts/whatsapp-cloud-smoke.mjs",
    "sonar": "node scripts/run-sonar.mjs",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "sonarqube-scanner": "4.3.6",
    "typescript-eslint": "8.61.0",
    "typescript": "6.0.3"
  }
}
