  "components": {
    "securitySchemes": {
      "BusinessBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Business dashboard access token with tenant scope derived server-side."
      },
      "AdminBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Platform admin access token with operator role and permissions."
      },
      "PaystackSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Paystack-Signature",
        "description": "HMAC-SHA512 signature over the raw Paystack webhook body."
      }
    },
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "BandId": {
        "name": "bandId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "Handle": {
        "name": "handle",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        }
      },
      "Code": {
        "name": "code",
        "in": "path",
